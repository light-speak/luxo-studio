extend Project {
  savedQueries: [SavedQuery]
}

model SavedQuery @crud {
  id:           Int @id @auto @serial
  projectId:    Int @by(Project) @filterable
  memberId:     Int @filterable @index
  name:         String @notBlank @varchar(200)
  apiName:      String @filterable
  params:       String?
  selectFields: String?
}
