enum TraceStatus {
  OK
  ERROR
}

extend Project {
  traces: [Trace]
}

model Trace @crud {
  id:            Int @id @auto @serial
  projectId:     Int @by(Project) @filterable
  gatewayId:     Int @filterable @index
  traceId:       String @unique @filterable
  apiName:       String @filterable
  duration:      Float @filterable @sortable
  status:        TraceStatus @filterable
  statusCode:    Int
  clientName:    String?
  clientVersion: String?
  timestamp:     DateTime @filterable @sortable
  spans:         String?
}

model MetricBucket @crud {
  id:            Int @id @auto @serial
  projectId:     Int @by(Project) @filterable
  gatewayId:     Int? @index
  serviceNodeId: Int? @index
  apiName:       String @filterable
  timestamp:     DateTime @filterable @sortable
  totalCount:    Int
  errCount:      Int
  avgMs:         Float
  p50Ms:         Float
  p95Ms:         Float
  p99Ms:         Float
}
