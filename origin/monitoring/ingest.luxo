// Trace batch ingest — target services push traces here (JSON string)
api ingestTraces(projectId: Int, traces: String): Boolean @auth @native

// Metric bucket ingest — target services push aggregated metrics (JSON string)
api ingestMetrics(projectId: Int, buckets: String): Boolean @auth @native

// Node heartbeat — gateways and services report status
api heartbeat(instanceId: String, status: String, memoryMB: Float, cpuPercent: Float): Boolean @auth @native
