error DuplicateEmail {
  code: 409
  message: "error.email_exists"
}

error InvalidCredentials {
  code: 401
  message: "error.invalid_credentials"
}

api register(name: String, email: String, password: String, teamSlug: String): Member @native

api login(email: String, password: String): Member @native

api me: Member @auth
